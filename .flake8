[flake8]
max-line-length = 120
exclude =
    .venv,
    __pycache__,
    .git
# W503: line break before binary operator (conflicts with PEP 8 recommendation)
# E402: module level import not at top (intentional — after dependency checks)
extend-ignore = W503
per-file-ignores =
    django-girls-offline.py:E402
    tutorial_api.py:E501
    django_girls_mcp_server.py:E501
    visuals.py:E501
